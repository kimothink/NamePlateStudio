<Window x:Class="NamePlateStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:helpers="clr-namespace:NamePlateStudio.Helpers"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="NamePlateStudio"
        Width="1280"
        Height="840"
        MinWidth="1040"
        MinHeight="700"
        Background="#F1F5F9"
        FontFamily="Malgun Gothic"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <helpers:AlignmentOffsetConverter x:Key="AlignmentOffsetConverter" />
        <helpers:ImagePathToImageSourceConverter x:Key="ImagePathToImageSourceConverter" />
        <helpers:MillimetersToPixelsConverter x:Key="MillimetersToPixelsConverter" />
        <helpers:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,9,0,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,18,0,4" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#475569" />
        </Style>

        <Style x:Key="ColorSelectButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="#334155" />
        </Style>

        <Style x:Key="PreviewCornerResizeThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Cursor" Value="SizeNWSE" />
            <Setter Property="Panel.ZIndex" Value="2" />
            <Setter Property="ToolTip" Value="꼭짓점을 끌어 비율을 유지하며 크기 조절" />
            <EventSetter Event="MouseEnter" Handler="PreviewImageResizeThumb_MouseEnter" />
            <EventSetter Event="DragStarted" Handler="PreviewImageResizeThumb_DragStarted" />
            <EventSetter Event="DragDelta" Handler="PreviewImageResizeThumb_DragDelta" />
            <EventSetter Event="DragCompleted" Handler="PreviewImageResizeThumb_DragCompleted" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="#2563EB"
                                BorderBrush="#FFFFFF"
                                BorderThickness="2"
                                CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewEdgeResizeThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Panel.ZIndex" Value="1" />
            <Setter Property="ToolTip" Value="변을 끌어 한 방향으로 크기 조절" />
            <EventSetter Event="MouseEnter" Handler="PreviewImageResizeThumb_MouseEnter" />
            <EventSetter Event="DragStarted" Handler="PreviewImageResizeThumb_DragStarted" />
            <EventSetter Event="DragDelta" Handler="PreviewImageResizeThumb_DragDelta" />
            <EventSetter Event="DragCompleted" Handler="PreviewImageResizeThumb_DragCompleted" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewRotateThumbStyle" TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Panel.ZIndex" Value="3" />
            <Setter Property="ToolTip" Value="이미지 회전 (Shift: 15° 단위)" />
            <EventSetter Event="DragStarted" Handler="PreviewImageRotateThumb_DragStarted" />
            <EventSetter Event="DragDelta" Handler="PreviewImageRotateThumb_DragDelta" />
            <EventSetter Event="DragCompleted" Handler="PreviewImageRotateThumb_DragCompleted" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Grid>
                            <Line X1="14" Y1="22" X2="14" Y2="43"
                                  Stroke="#2563EB"
                                  StrokeThickness="1.5"
                                  IsHitTestVisible="False" />
                            <Border Width="24"
                                    Height="24"
                                    VerticalAlignment="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="#2563EB"
                                    BorderThickness="2"
                                    CornerRadius="12">
                                <TextBlock Text="↻"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#2563EB" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="16"
                    Padding="0"
                    Background="#FFFFFF"
                    BorderBrush="#D8E0EA"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,18,8,18">
                        <TextBlock Text="명패 설정"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="{Binding PlateSizeText}"
                                   Margin="0,4,0,6"
                                   Foreground="#64748B" />

                        <TextBlock Text="명패 크기" Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="가로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding WidthMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="세로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding HeightMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,18,0,4">
                            <TextBlock Text="명패 내용 목록"
                                       Margin="0"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       VerticalAlignment="Center" />
                            <CheckBox Content="양면 인쇄 사용"
                                      IsChecked="{Binding IsDoubleSided}"
                                      HorizontalAlignment="Right"
                                      Margin="0"
                                      ToolTip="A4 용지에 앞면과 뒷면을 함께 미리보고 인쇄합니다." />
                        </Grid>
                        <TextBlock Text="각 행이 명패 1개로 출력됩니다. 소개 문구와 소속/메모는 비워도 됩니다."
                                   Margin="0,0,0,6"
                                   Foreground="#64748B" />
                        <DataGrid ItemsSource="{Binding Entries}"
                                  SelectedItem="{Binding SelectedEntry}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalScrollBarVisibility="Auto"
                                  RowHeaderWidth="0"
                                  MinHeight="138"
                                  MaxHeight="210"
                                  BorderBrush="#CBD5E1"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="표시명" Width="*" Binding="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="소개 문구" Width="*" Binding="{Binding TitleText, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="소속/메모" Width="1.2*" Binding="{Binding CompanyText, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTemplateColumn Header="뒷면" Width="88">
                                    <DataGridTemplateColumn.Visibility>Collapsed</DataGridTemplateColumn.Visibility>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="뒷면 편집"
                                                    Padding="6,2"
                                                    Visibility="Collapsed"
                                                    Command="{Binding DataContext.OpenBackEditorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="뒷면 문구" Width="1.4*" Binding="{Binding BackContent, UpdateSourceTrigger=PropertyChanged}" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <Button Content="항목 추가" Command="{Binding AddEntryCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="선택 삭제" Command="{Binding RemoveEntryCommand}" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                        </UniformGrid>

                        <TextBlock Text="선택 항목 그림" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding SelectedEntry.NameText, StringFormat=선택: {0}, TargetNullValue=선택된 항목 없음}"
                                   Margin="0,0,0,6"
                                   Foreground="#64748B" />
                        <Grid Margin="0,9,0,4">
                            <TextBlock Text="앞면 그림"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />
                            <CheckBox Content="모든 명찰에 적용"
                                      IsChecked="{Binding ApplyFrontImagesToAllEntries}"
                                      HorizontalAlignment="Right"
                                      Margin="0"
                                      FontWeight="SemiBold"
                                      ToolTip="현재 앞면 그림을 모든 명찰에 동일하게 적용합니다." />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="68" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SelectedEntry.OverlayImagePath, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Content="선택"
                                    Command="{Binding SelectEntryOverlayImageCommand}"
                                    Margin="8,4,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="삭제"
                                    Command="{Binding ClearEntryOverlayImageCommand}"
                                    Margin="8,4,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <UniformGrid Columns="3" Margin="0,4,0,0">
                            <Button Content="작게" Command="{Binding ScaleFrontImageCommand}" CommandParameter="0.9" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="크게" Command="{Binding ScaleFrontImageCommand}" CommandParameter="1.1" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="배경으로 꽉 채우기"
                                    Command="{Binding FitFrontImageCommand}"
                                    Margin="8,4,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    ToolTip="앞면 그림을 명패 전체 크기로 맞춥니다." />
                        </UniformGrid>

                        <TextBlock Text="선택 항목 뒷면" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="뒷면 문구" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Text="{Binding SelectedEntry.BackContent, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="70"
                                 VerticalContentAlignment="Top" />

                        <Grid Margin="0,12,0,4">
                            <TextBlock Text="뒷면 그림"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />
                            <CheckBox Content="전체 적용"
                                      IsChecked="{Binding ApplyBackImagesToAllEntries}"
                                      HorizontalAlignment="Right"
                                      Margin="0"
                                      FontWeight="SemiBold"
                                      ToolTip="현재 뒷면 그림을 모든 명찰에 동일하게 적용" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="68" />
                                <ColumnDefinition Width="68" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SelectedEntry.BackImagePath, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Content="선택"
                                    Command="{Binding SelectEntryBackImageCommand}"
                                    Margin="8,4,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="2"
                                    Content="삭제"
                                    Command="{Binding ClearEntryBackImageCommand}"
                                    Margin="8,4,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <UniformGrid Columns="3" Margin="0,8,0,0">
                            <Button Content="작게" Command="{Binding ScaleBackImageCommand}" CommandParameter="0.9" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="크게" Command="{Binding ScaleBackImageCommand}" CommandParameter="1.1" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="원본 전체" Command="{Binding FitBackImageCommand}" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                        </UniformGrid>

                        <TextBlock Margin="0,10,0,0"
                                   Text="변: 한 방향 크기 조절 · 꼭짓점: 비율 유지 · 꼭짓점 바깥 핸들: 회전"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#64748B" />

                        <TextBlock Text="글꼴" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding FontFamilies}"
                                  SelectedItem="{Binding SelectedFontFamily}"
                                  IsTextSearchEnabled="True" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="글자 크기" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="테두리 두께" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding BorderThickness, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="앞면 색상" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="글자 색상" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding FontBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding FontColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectFontColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <TextBlock Text="배경색" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding BackgroundBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding BackgroundColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectBackgroundColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <TextBlock Text="테두리 색상" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding BorderBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding BorderColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectBorderColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <TextBlock Text="뒷면 색상" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="뒷면 글자 색상" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding BackFontBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding BackFontColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectBackFontColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <Grid Margin="0,9,0,4">
                            <TextBlock Text="뒷면 배경색"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#334155" />
                            <CheckBox Content="그림 색상 자동"
                                      IsChecked="{Binding MatchBackBackgroundToImage}"
                                      HorizontalAlignment="Right"
                                      Margin="0"
                                      FontWeight="SemiBold"
                                      ToolTip="선택한 뒷면 그림의 특징적인 색상을 배경색으로 자동 적용" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding BackBackgroundBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding BackBackgroundColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectBackBackgroundColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <TextBlock Text="뒷면 테두리 색상" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Margin="0,4,8,4" RadiusX="3" RadiusY="3" Fill="{Binding BackBorderBrush}" Stroke="#CBD5E1" />
                            <TextBox Grid.Column="1" Text="{Binding BackBorderColor, Mode=OneWay}" IsReadOnly="True" />
                            <Button Grid.Column="2" Content="선택" Command="{Binding SelectBackBorderColorCommand}" Style="{StaticResource ColorSelectButtonStyle}" />
                        </Grid>

                        <TextBlock Text="스타일과 위치" Style="{StaticResource SectionTitleStyle}" />
                        <WrapPanel>
                            <CheckBox Content="굵게" IsChecked="{Binding IsBold}" />
                            <CheckBox Content="기울임" IsChecked="{Binding IsItalic}" />
                            <CheckBox Content="장식선" IsChecked="{Binding HasDecorationLine}" />
                        </WrapPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="좌우 정렬" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding HorizontalAlignmentOptions}" SelectedItem="{Binding HorizontalTextAlignment}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="상하 정렬" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding VerticalAlignmentOptions}" SelectedItem="{Binding VerticalTextAlignment}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="대표 문구 위치 X(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding PositionX, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="대표 문구 위치 Y(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding PositionY, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Button Content="텍스트 중앙"
                                Command="{Binding CenterTextCommand}"
                                Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButtonStyle}" />

                        <TextBlock Text="앞면 그림 위치" Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding OverlayImageX, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding OverlayImageY, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="가로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding OverlayImageWidth, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="세로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding OverlayImageHeight, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="용지와 다중 출력" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="용지" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding PaperSizes}"
                                  SelectedItem="{Binding SelectedPaperSize}"
                                  DisplayMemberPath="Name" />

                        <CheckBox Content="가로 방향" IsChecked="{Binding IsLandscape}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="용지 가로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding PaperWidthMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="용지 세로(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding PaperHeightMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="출력 항목 수" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding EntryCountText, Mode=OneWay}" IsReadOnly="True" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="용지 여백(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding PageMarginMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="가로 간격(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding HorizontalGapMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="세로 간격(mm)" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding VerticalGapMm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding LayoutSummaryText}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#475569" />

                        <UniformGrid Columns="2" Margin="0,18,0,0">
                            <Button Content="양식 저장" Command="{Binding SaveCommand}" />
                            <Button Content="양식 불러오기" Command="{Binding LoadCommand}" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="미리보기" Command="{Binding PreviewCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="인쇄" Command="{Binding PrintCommand}" Margin="8,4,0,0" />
                            <Button Content="초기화" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="종료" Click="ExitButton_Click" Margin="8,4,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="0,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="16"
                        Background="#FFFFFF"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="용지 미리보기"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="{Binding PaperSizeText}"
                                       Margin="0,4,0,0"
                                       Foreground="#64748B" />
                            <TextBlock Text="{Binding LayoutSummaryText}"
                                       Margin="0,3,0,0"
                                       Foreground="#64748B" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button Content="이전 페이지" Command="{Binding PreviousPreviewPageCommand}"
                                        Padding="10,4" Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock Text="{Binding PreviewPageText}" Margin="10,0" VerticalAlignment="Center" />
                                <Button Content="다음 페이지" Command="{Binding NextPreviewPageCommand}"
                                        Padding="10,4" Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                            <CheckBox Content="뒷면 미리보기"
                                      IsChecked="{Binding IsPreviewingBack}"
                                      IsEnabled="{Binding IsDoubleSided}"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,0,6" />
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="확대/축소"
                                           DockPanel.Dock="Left"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#334155" />
                                <TextBlock Text="{Binding ZoomPercentText}"
                                           DockPanel.Dock="Right"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#64748B" />
                                <Slider Minimum="0.2"
                                        Maximum="1.8"
                                        TickFrequency="0.1"
                                        Value="{Binding Zoom, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Background="#D8E0EA"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="PaperPreview_MouseWheel">
                        <Grid MinWidth="760" MinHeight="560">
                          <StackPanel Orientation="Horizontal"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                            <Canvas Width="{Binding EffectivePaperWidthPixels}"
                                    Height="{Binding EffectivePaperHeightPixels}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFF">
                                <Canvas.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                </Canvas.LayoutTransform>

                                <Rectangle Width="{Binding EffectivePaperWidthPixels}"
                                           Height="{Binding EffectivePaperHeightPixels}"
                                           Fill="#FFFFFF"
                                           Stroke="#94A3B8"
                                           StrokeThickness="1" />

                                <Rectangle Canvas.Left="{Binding PageMarginPixels}"
                                           Canvas.Top="{Binding PageMarginPixels}"
                                           Width="{Binding PrintableAreaWidthPixels}"
                                           Height="{Binding PrintableAreaHeightPixels}"
                                           Stroke="#CBD5E1"
                                           StrokeThickness="1"
                                           StrokeDashArray="4,4" />

                                <ItemsControl Width="{Binding EffectivePaperWidthPixels}"
                                              Height="{Binding EffectivePaperHeightPixels}"
                                              ItemsSource="{Binding PreviewPlacements}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding LeftPixels}" />
                                            <Setter Property="Canvas.Top" Value="{Binding TopPixels}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding WidthPixels}"
                                                  Height="{Binding HeightPixels}"
                                                  ClipToBounds="True">
                                              <Grid Width="{Binding WidthPixels}"
                                                  Height="{Binding HeightPixels}"
                                                  Background="{Binding DataContext.BackgroundBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  ClipToBounds="True">
                                                <Border Background="Transparent"
                                                        BorderBrush="{Binding DataContext.BorderBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        BorderThickness="{Binding DataContext.PreviewBorderThickness, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Panel.ZIndex="3"
                                                        IsHitTestVisible="False" />

                                                <Canvas Width="{Binding WidthPixels}" Height="{Binding HeightPixels}" ClipToBounds="True">
                                                    <Line X1="{Binding DataContext.DecorationLineStartX, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          X2="{Binding DataContext.DecorationLineEndX, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Y1="{Binding DataContext.DecorationTopLineY, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Y2="{Binding DataContext.DecorationTopLineY, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Stroke="{Binding DataContext.BorderBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          StrokeThickness="1.5"
                                                          Opacity="0.75"
                                                          Panel.ZIndex="2"
                                                          IsHitTestVisible="False"
                                                          Visibility="{Binding DataContext.HasDecorationLine, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <Line X1="{Binding DataContext.DecorationLineStartX, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          X2="{Binding DataContext.DecorationLineEndX, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Y1="{Binding DataContext.DecorationBottomLineY, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Y2="{Binding DataContext.DecorationBottomLineY, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Stroke="{Binding DataContext.BorderBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          StrokeThickness="1.5"
                                                          Opacity="0.75"
                                                          Panel.ZIndex="2"
                                                          IsHitTestVisible="False"
                                                          Visibility="{Binding DataContext.HasDecorationLine, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                    <Grid Canvas.Left="{Binding DataContext.OverlayImageXPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Canvas.Top="{Binding DataContext.OverlayImageYPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Width="{Binding DataContext.OverlayImageWidthPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Height="{Binding DataContext.OverlayImageHeightPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          Visibility="{Binding Entry.OverlayImagePath, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"
                                                          Background="Transparent"
                                                          Tag="FrontOverlay"
                                                          Panel.ZIndex="0"
                                                          Cursor="SizeAll"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                                          MouseMove="PreviewImage_MouseMove"
                                                          MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                                                          MouseWheel="PreviewImage_MouseWheel">
                                                        <Grid.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="배경으로 꽉 채우기" Tag="Fill" Click="PreviewImageContextMenu_Click" />
                                                                <MenuItem Header="좌회전" Tag="RotateLeft" Click="PreviewImageContextMenu_Click" />
                                                                <MenuItem Header="우회전" Tag="RotateRight" Click="PreviewImageContextMenu_Click" />
                                                            </ContextMenu>
                                                        </Grid.ContextMenu>
                                                        <Grid.RenderTransform>
                                                            <RotateTransform Angle="{Binding DataContext.OverlayImageRotation, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                        </Grid.RenderTransform>
                                                        <Image Source="{Binding Entry.OverlayImagePath, Converter={StaticResource ImagePathToImageSourceConverter}}"
                                                               Stretch="UniformToFill"
                                                               IsHitTestVisible="False" />
                                                        <Border BorderBrush="#2563EB"
                                                                BorderThickness="1"
                                                                Background="#11000000"
                                                                IsHitTestVisible="False" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Width="12"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Stretch"
                                                                          Margin="0,14,0,14"
                                                                          Cursor="SizeWE"
                                                                          Tag="Left" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Width="12"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Stretch"
                                                                          Margin="0,14,0,14"
                                                                          Cursor="SizeWE"
                                                                          Tag="Right" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Height="12"
                                                                          HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Top"
                                                                          Margin="14,0,14,0"
                                                                          Cursor="SizeNS"
                                                                          Tag="Top" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Height="12"
                                                                          HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="14,0,14,0"
                                                                          Cursor="SizeNS"
                                                                          Tag="Bottom" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Top"
                                                                          Cursor="SizeNWSE"
                                                                          Tag="TopLeft" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Top"
                                                                          Cursor="SizeNESW"
                                                                          Tag="TopRight" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Bottom"
                                                                          Cursor="SizeNESW"
                                                                          Tag="BottomLeft" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Bottom"
                                                                          Cursor="SizeNWSE"
                                                                          Tag="BottomRight" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Top"
                                                                          Margin="-34,-44,0,0" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Top"
                                                                          Margin="0,-44,-34,0" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="-34,0,0,-44"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                            <primitives:Thumb.RenderTransform>
                                                                <RotateTransform Angle="180" />
                                                            </primitives:Thumb.RenderTransform>
                                                        </primitives:Thumb>
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="0,0,-34,-44"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                            <primitives:Thumb.RenderTransform>
                                                                <RotateTransform Angle="180" />
                                                            </primitives:Thumb.RenderTransform>
                                                        </primitives:Thumb>
                                                    </Grid>

                                                    <TextBlock x:Name="CopyCompanyTextBlock"
                                                               Text="{Binding Entry.CompanyText}"
                                                               Canvas.Left="{Binding DataContext.PositionXPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Canvas.Top="{Binding DataContext.CompanyPositionYPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontFamily="{Binding DataContext.SelectedFontFamily, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontSize="{Binding DataContext.CompanyFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Foreground="{Binding DataContext.FontBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontStyle="{Binding DataContext.NameFontStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Panel.ZIndex="2"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform>
                                                                <TranslateTransform.X>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyCompanyTextBlock" Path="ActualWidth" />
                                                                        <Binding Path="DataContext.HorizontalTextAlignment" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.X>
                                                                <TranslateTransform.Y>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyCompanyTextBlock" Path="ActualHeight" />
                                                                        <Binding Source="가운데" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.Y>
                                                            </TranslateTransform>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>

                                                    <TextBlock x:Name="CopyNameTextBlock"
                                                               Text="{Binding Entry.NameText}"
                                                               Canvas.Left="{Binding DataContext.PositionXPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Canvas.Top="{Binding DataContext.PositionYPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontFamily="{Binding DataContext.SelectedFontFamily, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontWeight="{Binding DataContext.NameFontWeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontStyle="{Binding DataContext.NameFontStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Foreground="{Binding DataContext.FontBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Panel.ZIndex="2"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform>
                                                                <TranslateTransform.X>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyNameTextBlock" Path="ActualWidth" />
                                                                        <Binding Path="DataContext.HorizontalTextAlignment" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.X>
                                                                <TranslateTransform.Y>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyNameTextBlock" Path="ActualHeight" />
                                                                        <Binding Path="DataContext.VerticalTextAlignment" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.Y>
                                                            </TranslateTransform>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>

                                                    <TextBlock x:Name="CopyTitleTextBlock"
                                                               Text="{Binding Entry.TitleText}"
                                                               Canvas.Left="{Binding DataContext.PositionXPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Canvas.Top="{Binding DataContext.TitlePositionYPixels, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontFamily="{Binding DataContext.SelectedFontFamily, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontSize="{Binding DataContext.TitleFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Foreground="{Binding DataContext.FontBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontStyle="{Binding DataContext.NameFontStyle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Panel.ZIndex="2"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform>
                                                                <TranslateTransform.X>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyTitleTextBlock" Path="ActualWidth" />
                                                                        <Binding Path="DataContext.HorizontalTextAlignment" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.X>
                                                                <TranslateTransform.Y>
                                                                    <MultiBinding Converter="{StaticResource AlignmentOffsetConverter}">
                                                                        <Binding ElementName="CopyTitleTextBlock" Path="ActualHeight" />
                                                                        <Binding Source="가운데" />
                                                                    </MultiBinding>
                                                                </TranslateTransform.Y>
                                                            </TranslateTransform>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </Canvas>

                                                <Rectangle Stroke="#475569"
                                                           StrokeThickness="1"
                                                           StrokeDashArray="5,3"
                                                           Panel.ZIndex="4"
                                                           IsHitTestVisible="False" />
                                              </Grid>

                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>

                            <Canvas Width="{Binding EffectivePaperWidthPixels}"
                                    Height="{Binding EffectivePaperHeightPixels}"
                                    Margin="18,0,0,0"
                                    Background="#FFFFFF"
                                    Visibility="{Binding IsDoubleSided, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Canvas.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                </Canvas.LayoutTransform>

                                <Rectangle Width="{Binding EffectivePaperWidthPixels}"
                                           Height="{Binding EffectivePaperHeightPixels}"
                                           Fill="#FFFFFF"
                                           Stroke="#EF4444"
                                           StrokeThickness="3" />
                                <Rectangle Canvas.Left="{Binding PageMarginPixels}"
                                           Canvas.Top="{Binding PageMarginPixels}"
                                           Width="{Binding PrintableAreaWidthPixels}"
                                           Height="{Binding PrintableAreaHeightPixels}"
                                           Stroke="#FCA5A5"
                                           StrokeThickness="1"
                                           StrokeDashArray="4,4" />

                                <TextBlock Text="뒷면"
                                           Canvas.Left="12" Canvas.Top="8"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="#DC2626" />

                                <ItemsControl Width="{Binding EffectivePaperWidthPixels}"
                                              Height="{Binding EffectivePaperHeightPixels}"
                                              ItemsSource="{Binding PreviewPlacements}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding LeftPixels}" />
                                            <Setter Property="Canvas.Top" Value="{Binding TopPixels}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding WidthPixels}"
                                                  Height="{Binding HeightPixels}"
                                                  Background="{Binding DataContext.BackBackgroundBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  ClipToBounds="True">
                                                <Canvas Width="{Binding WidthPixels}"
                                                        Height="{Binding HeightPixels}"
                                                        Panel.ZIndex="0"
                                                        ClipToBounds="True">
                                                    <Grid Canvas.Left="{Binding Entry.BackImageX, Converter={StaticResource MillimetersToPixelsConverter}, ConverterParameter=Signed}"
                                                          Canvas.Top="{Binding Entry.BackImageY, Converter={StaticResource MillimetersToPixelsConverter}, ConverterParameter=Signed}"
                                                          Width="{Binding Entry.BackImageWidthMm, Converter={StaticResource MillimetersToPixelsConverter}}"
                                                          Height="{Binding Entry.BackImageHeightMm, Converter={StaticResource MillimetersToPixelsConverter}}"
                                                          Visibility="{Binding Entry.BackImagePath, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"
                                                          Background="Transparent"
                                                          Tag="BackImage"
                                                          Cursor="SizeAll"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                                          MouseMove="PreviewImage_MouseMove"
                                                          MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                                                          MouseWheel="PreviewImage_MouseWheel">
                                                        <Grid.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="꽉 차게" Tag="Fill" Click="PreviewImageContextMenu_Click" />
                                                                <MenuItem Header="좌회전" Tag="RotateLeft" Click="PreviewImageContextMenu_Click" />
                                                                <MenuItem Header="우회전" Tag="RotateRight" Click="PreviewImageContextMenu_Click" />
                                                            </ContextMenu>
                                                        </Grid.ContextMenu>
                                                        <Grid.RenderTransform>
                                                            <RotateTransform Angle="{Binding Entry.BackImageRotation}" />
                                                        </Grid.RenderTransform>
                                                        <Image Source="{Binding Entry.BackImagePath, Converter={StaticResource ImagePathToImageSourceConverter}}"
                                                               Stretch="Uniform"
                                                               IsHitTestVisible="False" />
                                                        <Border BorderBrush="#2563EB"
                                                                BorderThickness="1"
                                                                Background="#11000000"
                                                                IsHitTestVisible="False" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Width="12"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Stretch"
                                                                          Margin="0,14,0,14"
                                                                          Cursor="SizeWE"
                                                                          Tag="Left" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Width="12"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Stretch"
                                                                          Margin="0,14,0,14"
                                                                          Cursor="SizeWE"
                                                                          Tag="Right" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Height="12"
                                                                          HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Top"
                                                                          Margin="14,0,14,0"
                                                                          Cursor="SizeNS"
                                                                          Tag="Top" />
                                                        <primitives:Thumb Style="{StaticResource PreviewEdgeResizeThumbStyle}"
                                                                          Height="12"
                                                                          HorizontalAlignment="Stretch"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="14,0,14,0"
                                                                          Cursor="SizeNS"
                                                                          Tag="Bottom" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Top"
                                                                          Cursor="SizeNWSE"
                                                                          Tag="TopLeft" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Top"
                                                                          Cursor="SizeNESW"
                                                                          Tag="TopRight" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Bottom"
                                                                          Cursor="SizeNESW"
                                                                          Tag="BottomLeft" />
                                                        <primitives:Thumb Style="{StaticResource PreviewCornerResizeThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Bottom"
                                                                          Cursor="SizeNWSE"
                                                                          Tag="BottomRight" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Top"
                                                                          Margin="-34,-44,0,0" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Top"
                                                                          Margin="0,-44,-34,0" />
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="-34,0,0,-44"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                            <primitives:Thumb.RenderTransform>
                                                                <RotateTransform Angle="180" />
                                                            </primitives:Thumb.RenderTransform>
                                                        </primitives:Thumb>
                                                        <primitives:Thumb Style="{StaticResource PreviewRotateThumbStyle}"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Bottom"
                                                                          Margin="0,0,-34,-44"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                            <primitives:Thumb.RenderTransform>
                                                                <RotateTransform Angle="180" />
                                                            </primitives:Thumb.RenderTransform>
                                                        </primitives:Thumb>
                                                    </Grid>
                                                </Canvas>
                                                <Border BorderBrush="{Binding DataContext.BackBorderBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Panel.ZIndex="1"
                                                        BorderThickness="{Binding DataContext.PreviewBorderThickness, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Padding="22">
                                                    <TextBlock Text="{Binding Entry.BackContent}"
                                                               FontFamily="{Binding DataContext.SelectedFontFamily, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               FontSize="{Binding DataContext.BackFontSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               Foreground="{Binding DataContext.BackFontBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding Entry.BackTableCells}"
                                                              Visibility="Collapsed"
                                                              VerticalAlignment="Bottom"
                                                              Margin="18">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="{Binding DataContext.Entry.BackTableRows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                         Columns="{Binding DataContext.Entry.BackTableColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#475569" BorderThickness="0.5" Padding="3">
                                                                <TextBlock Text="{Binding}" TextAlignment="Center" TextWrapping="Wrap" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Rectangle Stroke="#475569" Panel.ZIndex="2" StrokeThickness="1" StrokeDashArray="5,3" IsHitTestVisible="False" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                          </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Padding="14,8"
                Background="#0F172A">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#E2E8F0"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
