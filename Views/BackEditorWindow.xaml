<Window x:Class="NamePlateStudio.Views.BackEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="명찰 뒷면 편집" Width="720" Height="760"
        MinWidth="620" MinHeight="620"
        WindowStartupLocation="CenterOwner" FontFamily="Malgun Gothic"
        Background="#F1F5F9">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="글, 그림, 표를 한 화면에서 작성할 수 있습니다." Margin="0,4,0,12" Foreground="#64748B" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="글 내용" FontWeight="SemiBold" Margin="0,8,0,4" />
                <TextBox x:Name="BackTextBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="110" />

                <TextBlock Text="그림" FontWeight="SemiBold" Margin="0,16,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="80" /><ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImagePathTextBox" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="선택" Margin="8,0,0,0" Click="SelectImage_Click" />
                    <Button Grid.Column="2" Content="삭제" Margin="8,0,0,0" Click="ClearImage_Click" />
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="120" />
                        <ColumnDefinition Width="24" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="그림 너비(mm)" VerticalAlignment="Center" />
                    <TextBox x:Name="ImageWidthTextBox" Grid.Column="1" Margin="8,0,0,0" TextChanged="ImageSizeTextBox_TextChanged" />
                    <TextBlock Grid.Column="3" Text="그림 높이(mm)" VerticalAlignment="Center" />
                    <TextBox x:Name="ImageHeightTextBox" Grid.Column="4" Margin="8,0,0,0" TextChanged="ImageSizeTextBox_TextChanged" />
                </Grid>

                <Border Height="230" Margin="0,10,0,0" Background="#E2E8F0"
                        BorderBrush="#94A3B8" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="이미지를 선택한 뒤 오른쪽 아래 핸들을 끌어 크기를 조절하세요."
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Margin="8" Foreground="#64748B" />
                        <Grid x:Name="ResizableImageContainer"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="ImagePreview" Stretch="Uniform" />
                            <primitives:Thumb Width="20" Height="20"
                                              HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Cursor="SizeNWSE" DragDelta="ResizeImageThumb_DragDelta">
                                <primitives:Thumb.Template>
                                    <ControlTemplate TargetType="primitives:Thumb">
                                        <Border Background="#2563EB" BorderBrush="White" BorderThickness="2" CornerRadius="3" />
                                    </ControlTemplate>
                                </primitives:Thumb.Template>
                            </primitives:Thumb>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="표" FontWeight="SemiBold" Margin="0,16,0,4" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="행" VerticalAlignment="Center" />
                    <TextBox x:Name="RowsTextBox" Width="70" Margin="8,0,18,0" />
                    <TextBlock Text="열" VerticalAlignment="Center" />
                    <TextBox x:Name="ColumnsTextBox" Width="70" Margin="8,0,18,0" />
                    <Button Content="표 만들기/변경" Padding="14,5" Click="BuildTable_Click" />
                    <Button Content="표 삭제" Padding="14,5" Margin="8,0,0,0" Click="ClearTable_Click" />
                </StackPanel>
                <DataGrid x:Name="TableEditor" Margin="0,8,0,0" MinHeight="180"
                          AutoGenerateColumns="True" CanUserAddRows="False" HeadersVisibility="Column" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <CheckBox x:Name="ApplyAllCheckBox" Content="전체 명찰에 일괄 적용" VerticalAlignment="Center" FontWeight="SemiBold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="취소" Width="90" Padding="10,6" Click="Cancel_Click" />
                <Button Content="저장" Width="100" Padding="10,6" Margin="8,0,0,0" Click="Save_Click"
                        Background="#334155" Foreground="White" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
